{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write",
    "ui.svg"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:mini-notes-summary",
      "min_version": "0.1.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "The user has Mini Notes open. Notes are stored through Anna storage Host API. The Summarize button calls the bundled mini-notes-summary Executa with method='summarize'; that Executa requests host LLM sampling through sampling/createMessage.",
  "tags": [
    "notes",
    "summary",
    "executa",
    "sampling"
  ],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,
        "entry": "index.html",
        "min_size": {
          "w": 360,
          "h": 520
        },
        "default_size": {
          "w": 520,
          "h": 720
        },
        "max_size": {
          "w": 900,
          "h": 1000
        },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": [
        "required:bundled:mini-notes-summary"
      ],
      "chat": [],
      "artifact": [],
      "llm": [],
      "fs": [],
      "storage": [
        "get",
        "set"
      ],
      "prefs": [],
      "window": [
        "set_title"
      ]
    },
    "csp_overrides": {
      "img-src": [
        "'self'",
        "data:",
        "blob:"
      ],
      "font-src": [
        "'self'",
        "data:"
      ],
      "style-src": [
        "'self'"
      ],
      "script-src": [
        "'self'"
      ]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": [
      "fixtures/*.jsonl"
    ],
    "seed_storage": {},
    "user_id": 1
  }
}
